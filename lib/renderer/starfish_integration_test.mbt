///|
test "starfish integration" {
  try {
    let json = @json.parse(STARFISH_JSON)
    let animation = @parser.parse_animation(json)
    let svg_frames = @renderer.render_animation_to_svgs(animation, 301)

    // 统计包含路径的帧数
    let mut frames_with_paths = 0
    for frame in svg_frames {
      if frame.contains("<path") {
        frames_with_paths = frames_with_paths + 1
      }
    }

    println("Frames with paths: \{frames_with_paths}/\{svg_frames.length()}")

    if frames_with_paths == 0 {
      fail("Animation should render at least one path across all frames")
    }
  } catch {
    e => fail("Starfish test failed with error: \{e}")
  }
}

///|
fn assert_true(cond : Bool, msg : String) -> Unit raise {
  if not(cond) {
    fail(msg)
  }
}
