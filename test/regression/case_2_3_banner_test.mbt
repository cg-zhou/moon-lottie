test "regression/2-3 banner" {
  let json_data = get_json_2_3_banner()
  let snapshots : Array[RegressionSnapshot] = [
    { frame: 0.0, svg: get_svg_2_3_banner_f0() },
    { frame: 25.0, svg: get_svg_2_3_banner_f25() },
    { frame: 50.0, svg: get_svg_2_3_banner_f50() },
    { frame: 75.0, svg: get_svg_2_3_banner_f75() },
    { frame: 99.0, svg: get_svg_2_3_banner_f99() },
  ]
  run_regression_test(json_data, snapshots)
}
