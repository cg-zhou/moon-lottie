test "regression/1-4 Cat Fishing On Moon" {
  let json_data = get_json_1_4_Cat_Fishing_On_Moon()
  let snapshots : Array[RegressionSnapshot] = [
    { frame: 0.0, svg: get_svg_1_4_Cat_Fishing_On_Moon_f0() },
    { frame: 25.0, svg: get_svg_1_4_Cat_Fishing_On_Moon_f25() },
