test "regression/2-1 adrock" {
  let json_data = get_json_2_1_adrock()
  let snapshots : Array[RegressionSnapshot] = [
    { frame: 0.0, svg: get_svg_2_1_adrock_f0() },
    { frame: 25.0, svg: get_svg_2_1_adrock_f25() },
    { frame: 50.0, svg: get_svg_2_1_adrock_f50() },
    { frame: 75.0, svg: get_svg_2_1_adrock_f75() },
    { frame: 99.0, svg: get_svg_2_1_adrock_f99() },
  ]
  run_regression_test(json_data, snapshots)
}
