test "regression/3-4 ripple(expr)" {
  let json_data = get_json_3_4_ripple_expr_()
  let snapshots : Array[RegressionSnapshot] = [
    { frame: 0.0, svg: get_svg_3_4_ripple_expr__f0() },
    { frame: 25.0, svg: get_svg_3_4_ripple_expr__f25() },
    { frame: 50.0, svg: get_svg_3_4_ripple_expr__f50() },
    { frame: 75.0, svg: get_svg_3_4_ripple_expr__f75() },
    { frame: 99.0, svg: get_svg_3_4_ripple_expr__f99() },
  ]
  run_regression_test(json_data, snapshots)
}
