test "regression/1-3 Businessman flies up with rocket" {
  let json_data = get_json_1_3_Businessman_flies_up_with_rocket()
  let snapshots : Array[RegressionSnapshot] = [
    { frame: 0.0, svg: get_svg_1_3_Businessman_flies_up_with_rocket_f0() },
    { frame: 25.0, svg: get_svg_1_3_Businessman_flies_up_with_rocket_f25() },
    { frame: 50.0, svg: get_svg_1_3_Businessman_flies_up_with_rocket_f50() },
    { frame: 75.0, svg: get_svg_1_3_Businessman_flies_up_with_rocket_f75() },
    { frame: 99.0, svg: get_svg_1_3_Businessman_flies_up_with_rocket_f99() },
  ]
  run_regression_test(json_data, snapshots)
}
