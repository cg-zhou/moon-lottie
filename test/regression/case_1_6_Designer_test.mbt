test "regression/1-6 Designer" {
  let json_data = get_json_1_6_Designer()
  let snapshots : Array[RegressionSnapshot] = [
    { frame: 0.0, svg: get_svg_1_6_Designer_f0() },
    { frame: 25.0, svg: get_svg_1_6_Designer_f25() },
    { frame: 50.0, svg: get_svg_1_6_Designer_f50() },
    { frame: 75.0, svg: get_svg_1_6_Designer_f75() },
    { frame: 99.0, svg: get_svg_1_6_Designer_f99() },
  ]
  run_regression_test(json_data, snapshots)
}
